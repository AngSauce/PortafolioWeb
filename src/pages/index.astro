---
import Layout from '../layouts/Layout.astro';
---

<Layout>
		<article class="float-left h-full justify-items-center content-center  p-4 flex">
			<button 
			class="flex h-20 my-auto text-white bg-gradient-to-br from-purple-600 to-blue-500 hover:bg-gradient-to-bl focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800 font-medium rounded-base text-sm px-4 py-2.5 text-center leading-5" 
			set:text="<"></button>
		</article>
		<article class="float-right h-full justify-items-center content-center  p-4 flex">
			<button 
			class="flex h-20 my-auto text-white bg-gradient-to-br from-purple-600 to-blue-500 hover:bg-gradient-to-bl focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800 font-medium rounded-base text-sm px-4 py-2.5 text-center leading-5" 
			set:text=">"></button>
		</article>
	<main>
		<section class="w-full mx-auto lg:max-w-[740px] py-4 px-2">
			<h1 class="text-xl font-bold">Contenido</h1>
			<h2 class="text-lg text-justify">Lorem ipsum dolor sit amet consectetur adipisicing elit. Eum dolore eos laudantium voluptas ea ab, voluptatem omnis reprehenderit atque voluptatibus. Temporibus sit, nulla possimus assumenda exercitationem qui consectetur nobis facere mollitia recusandae, dignissimos tenetur enim consequuntur, pariatur aliquam. Accusantium cupiditate harum dolorum at soluta sapiente repudiandae placeat numquam hic id?.</h2>
			<div class="flex flex-row">
			<span class="bg-neutral-secondary-medium text-heading text-xs font-medium px-1.5 py-0.5 rounded">Gray</span>
			<span class="bg-neutral-secondary-medium text-heading text-xs font-medium px-1.5 py-0.5 rounded">Gray</span>
			<span class="bg-neutral-secondary-medium text-heading text-xs font-medium px-1.5 py-0.5 rounded">Gray</span>
			<span class="bg-neutral-secondary-medium text-heading text-xs font-medium px-1.5 py-0.5 rounded">Gray</span>
			<span class="bg-neutral-secondary-medium text-heading text-xs font-medium px-1.5 py-0.5 rounded">Gray</span>
			</div>
		</section>
	</main>
</Layout>
