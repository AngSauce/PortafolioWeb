interface ProjectImage {
  url: string;
  alt?: string;
}

interface RawProject {
  name: string;
  description?: string;
  images?: ProjectImage[];
  video?: string;
  idvideo?: string;
  url?: string;
}

type SectionKey = 'icest' | 'tibugames' | 'expertices';

type Slide =
  | { type: 'image'; src: string; alt: string }
  | { type: 'video'; videoId: string }
  | { type: 'placeholder' };

const sectionOrder: SectionKey[] = ['icest', 'tibugames', 'expertices'];
const folderMap: Record<SectionKey, string> = {
  icest: 'icest',
  tibugames: 'tibugame',
  expertices: 'expertices',
};

const sectionLabels: Record<SectionKey, string> = {
  icest: 'Icest en Línea',
  tibugames: 'TiBu Games',
  expertices: 'Expertices',
};

const placeholderDescription =
  'Contenido en proceso. Estoy actualizando esta sección con los detalles más recientes.';

const projectSections = (cv.projects?.[0] ?? {}) as Partial<Record<SectionKey, RawProject[]>>;

const assetMap: Record<string, string> = import.meta.glob('../assets/Proyectos/**', {
  query: '?url',
  import: 'default',
  eager: true,
});

const resolveImageUrl = (folder: string, file?: string) => {
  if (!file) return undefined;
  const candidate = `../assets/Proyectos/${folder}/${file}`;
  return assetMap[candidate];
};

const extractYouTubeId = (value?: string) => {
  if (!value) return undefined;
  const patterns = [/v=([\w-]+)/, /youtu\.be\/([\w-]+)/, /embed\/([\w-]+)/];
  for (const pattern of patterns) {
    const match = value.match(pattern);
    if (match?.[1]) return match[1];
  }
  return undefined;
};

const sections = sectionOrder.map((key) => {
  const entries = projectSections[key] ?? [];
  const project: RawProject = entries[0] ?? {
    name: sectionLabels[key],
    description: placeholderDescription,
    images: [],
  };
  const slides: Slide[] = [];

  (project.images ?? []).forEach((image) => {
    const src = resolveImageUrl(folderMap[key], image.url);
    if (src) {
      slides.push({
        type: 'image',
        src,
        alt: image.alt ?? project.name ?? sectionLabels[key],
      });
    }
  });

  const videoId = project.idvideo ?? extractYouTubeId(project.video);
  if (videoId) {
    slides.push({ type: 'video', videoId });
  }

  if (!slides.length) {
    slides.push({ type: 'placeholder' });
  }

  return {
    key,
    label: sectionLabels[key] ?? project.name ?? 'Proyecto',
    project,
    slides,
  };
});
