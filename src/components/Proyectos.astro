<section class="mx-6 md:mx-20" aria-label="Proyectos destacados">
  <div class="text-3xl font-bold my-3 mx-2">Proyectos</div>
  <div
    id="slider"
    class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory px-4 py-6 cursor-grab select-none [&::-webkit-scrollbar]:hidden"
  >
    {sections.map((section, cardIndex) => (
      <article
        id={`card${cardIndex + 1}`}
        data-card
        class={
          'snap-start w-full min-w-190 min-h-110 bg-white rounded-xl shadow-2xl overflow-hidden flex flex-col hover:scale-105 transition-transform duration-300 border border-gray-100'
        }
      >
        <div class="px-4 pt-5">
          <p class="text-xs uppercase tracking-[0.4em] text-gray-400">{section.label}</p>
          <h3 class="text-xl font-bold text-gray-900 mt-2">{section.project.name ?? section.label}</h3>
          <p class="text-sm text-gray-600 leading-relaxed mt-2">
            {section.project.description?.trim() || placeholderDescription}
          </p>
        </div>
        <div class="relative px-4 pt-4 pb-6">
          <div class="relative h-64 md:h-72" data-card-carousel>
            {section.slides.map((slide, slideIndex) => (
              <div
                class="transition-opacity duration-500 ease-in-out opacity-0 absolute inset-0 flex items-center justify-center bg-gray-100"
                data-carousel-item
                data-slide-index={slideIndex}
              >
                {slide.type === 'image' ? (
                  <img src={slide.src} alt={slide.alt} class="h-full w-full object-cover" loading="lazy" />
                ) : slide.type === 'video' ? (
                  <lite-youtube videoid={slide.videoId} style="width:100%;height:100%;"></lite-youtube>
                ) : (
                  <div class="text-xs text-gray-400 uppercase tracking-[0.4em]">
                    Próximamente
                  </div>
                )}
              </div>
            ))}
          </div>
          <div class="absolute inset-0 flex items-center justify-between px-3 pointer-events-none">
            <button
              type="button"
              data-card-carousel-prev
              class="pointer-events-auto bg-white/80 text-gray-700 text-sm font-semibold rounded-full p-2 shadow focus:outline-none focus:ring-2 focus:ring-indigo-500"
              aria-label="Anterior"
            >
              ‹
            </button>
            <button
              type="button"
              data-card-carousel-next
              class="pointer-events-auto bg-white/80 text-gray-700 text-sm font-semibold rounded-full p-2 shadow focus:outline-none focus:ring-2 focus:ring-indigo-500"
              aria-label="Siguiente"
            >
              ›
            </button>
          </div>
        </div>
        <div class="px-4 pb-5 flex items-center justify-between gap-3 text-xs text-gray-500">
          {section.project.url ? (
            <a
              class="text-blue-700 hover:text-blue-900 font-semibold"
              href={section.project.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              Ver sitio
            </a>
          ) : (
            <span class="text-gray-400">Sin enlace público</span>
          )}
          <span>{section.slides.length} elementos</span>
        </div>
      </article>
    ))}
  </div>
</section>

<script is:inline>
  const slider = document.querySelector('#slider');
  if (slider) {
    let isDown = false;
    let startX;
    let scrollLeft;
    slider.addEventListener('mousedown', (e) => {
      isDown = true;
      slider.classList.add('cursor-grabbing');
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
    });
    slider.addEventListener('mouseup', () => {
      isDown = false;
      slider.classList.remove('cursor-grabbing');
    });
    slider.addEventListener('mouseleave', () => {
      isDown = false;
      slider.classList.remove('cursor-grabbing');
    });
    slider.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - slider.offsetLeft;
      const walk = (x - startX) * 2;
      slider.scrollLeft = scrollLeft - walk;
    });
  }

  const carousels = document.querySelectorAll('[data-card-carousel]');
  carousels.forEach((carousel) => {
    const card = carousel.closest('[data-card]');
    if (!card) return;
    const items = Array.from(carousel.querySelectorAll('[data-carousel-item]'));
    if (!items.length) return;
    let current = 0;

    const showItem = (index) => {
      items.forEach((item, idx) => {
        const isActive = idx === index;
        item.classList.toggle('opacity-100', isActive);
        item.classList.toggle('opacity-0', !isActive);
        item.style.zIndex = isActive ? '1' : '0';
      });
    };

    showItem(current);

    const prevButton = card.querySelector('[data-card-carousel-prev]');
    const nextButton = card.querySelector('[data-card-carousel-next]');

    prevButton?.addEventListener('click', () => {
      current = (current - 1 + items.length) % items.length;
      showItem(current);
    });

    nextButton?.addEventListener('click', () => {
      current = (current + 1) % items.length;
      showItem(current);
    });
  });
</script>
