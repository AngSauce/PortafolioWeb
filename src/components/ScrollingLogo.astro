---
import { Tailwindcss, Html5, Css, Javascript, Typescript, React, Astro, Git, Nodedotjs, Bootstrap, Unity } from 'simple-icons-astro';
interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;

const technologies = [
  { name: 'HTML', icon: Html5, color: 'text-orange-500', enlace: 'https://developer.mozilla.org/es/docs/Web/HTML' },
  { name: 'CSS', icon: Css, color: 'text-blue-500', enlace: 'https://developer.mozilla.org/es/docs/Web/CSS' },
  { name: 'JavaScript', icon: Javascript, color: 'text-yellow-500', enlace: 'https://developer.mozilla.org/es/docs/Web/JavaScript' },
  { name: 'TypeScript', icon: Typescript, color: 'text-blue-600', enlace: 'https://www.typescriptlang.org/' },
  { name: 'React', icon: React, color: 'text-cyan-500', enlace: 'https://reactjs.org/' },
  { name: 'Tailwind CSS', icon: Tailwindcss, color: 'text-cyan-400', enlace: 'https://tailwindcss.com/' },
  { name: 'Astro', icon: Astro, color: 'text-orange-400', enlace: 'https://astro.build/' },
  { name: 'Node.js', icon: Nodedotjs, color: 'text-green-600', enlace: 'https://nodejs.org/' },
  { name: 'Git', icon: Git, color: 'text-red-500', enlace: 'https://git-scm.com/' },
  { name: 'Bootstrap', icon: Bootstrap, color: 'text-purple-500', enlace: 'https://getbootstrap.com/' },
  { name: 'Unity', icon: Unity, color: 'text-purple-500', enlace: 'https://unity.com/' },
];
---

<div class={`w-full overflow-hidden bg-gradient-to-r from-transparent via-slate-900 to-transparent py-8 ${className}`}>
  <style>
    @keyframes scroll {
      0% {
        transform: translateX(50%);
      }
      100% {
        transform: translateX(-50%);
      }
    }

    .tech-scroll {
      animation: scroll 60s linear infinite;
    }

    .tech-scroll:hover {
      animation-play-state: paused;
    }
  </style>

<div class="tech-scroll flex gap-8 whitespace-nowrap">
  {technologies.map((tech) => {
    const Icon = tech.icon;

    return (
      <div class="flex flex-col items-center gap-2 min-w-max">
        <div class="text-5xl transition-transform hover:scale-110 duration-300">
            <a href={tech.enlace} target="_blank" rel="noopener noreferrer">
        {Icon
        ? (typeof Icon === 'function'
            ? <Icon size={40} />
            : Icon)
            : (
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8.358 20.162c-1.186-1.07-1.532-3.316-1.038-4.944.856 1.026 2.043 1.352 3.272 1.535 1.897.283 3.76.177 5.522-.678.202-.098.388-.229.608-.36.166.473.209.95.151 1.437-.14 1.185-.738 2.1-1.688 2.794-.38.277-.782.525-1.175.787-1.205.804-1.531 1.747-1.078 3.119l.044.148a3.158 3.158 0 0 1-1.407-1.188 3.31 3.31 0 0 1-.544-1.815c-.004-.32-.004-.642-.048-.958-.106-.769-.472-1.113-1.161-1.133-.707-.02-1.267.411-1.415 1.09-.012.053-.028.104-.045.165h.002zm-5.961-4.445s3.24-1.575 6.49-1.575l2.451-7.565c.092-.366.36-.614.662-.614.302 0 .57.248.662.614l2.45 7.565c3.85 0 6.491 1.575 6.491 1.575L16.088.727C15.93.285 15.663 0 15.303 0H8.697c-.36 0-.615.285-.784.727l-5.516 14.99z" />
            </svg>
            )
        }
            </a>
        </div>
        <span class="text-sm font-medium text-gray-300">
          {tech.name}
        </span>
      </div>
    );
  })}
    {technologies.map((tech) => {
