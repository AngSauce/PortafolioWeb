<div class="bg-paint -z-20">
    <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
    <defs>
        <filter id="blur">
        <feGaussianBlur stdDeviation="60" />
        </filter>

        <filter id="noise">
        <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" />
        <feBlend mode="overlay" in2="SourceGraphic"/>
        </filter>
    </defs>

    
    <path d="M150,300 C200,100 400,100 450,300 C500,500 250,550 150,300 Z"
            fill="#0a2a80" filter="url(#blur)" opacity="0.5"/>

    
    <path d="M500,200 C650,50 750,250 650,400 C550,550 400,350 500,200 Z"
            fill="#051e5a" filter="url(#blur)" opacity="0.4"/>
</div>

<style>

.bg-paint {
position: fixed;
inset: 0;
